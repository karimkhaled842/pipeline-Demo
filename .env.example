# Application settings — copy this file to .env and fill in real values

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SecureApp
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/app_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CACHE_TTL=300

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ENABLE_METRICS=true
ENABLE_TRACING=false
